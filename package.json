{
  "private": true,
  "name": "root",
  "version": "13.0.2",
  "description": "Pluggable linting tool to prevent commit secret/credential file.",
  "type": "module",
  "keywords": [
    "secret",
    "credential",
    "lint",
    "linting",
    "git"
  ],
  "homepage": "https://github.com/secretlint/secretlint",
  "bugs": {
    "url": "https://github.com/secretlint/secretlint/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/secretlint/secretlint.git"
  },
  "license": "MIT",
  "author": "azu",
  "workspaces": [
    "packages/*",
    "packages/@secretlint/*",
    "examples/*"
  ],
  "scripts": {
    "versionup": "echo 'Error: Please use CI for versioning. Run the GitHub Actions workflow instead.' && exit 1",
    "release": "echo 'Error: Please use CI for releases. Run the GitHub Actions workflow instead.' && exit 1",
    "build": "turbo run build",
    "build:withoutrule": "turbo run build --ignore=\"packages/@secretlint/*-rule-*\"",
    "updateSnapshot": "turbo run updateSnapshot",
    "test": "turbo run test",
    "lint": "secretlint \"**/*\"",
    "ci": "turbo run build test secretlint",
    "clean": "turbo run clean",
    "prepare": "git config --local core.hooksPath .githooks",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,css}\"",
    "gen:rule": "scaffdog generate new-rule --output packages/ --answer \"owner:$(git config user.name)\" --answer \"version:$(node -e 'console.log(require(\"./package.json\").version)')\""
  },
  "devDependencies": {
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "scaffdog": "catalog:",
    "turbo": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": {
    "singleQuote": false,
    "printWidth": 120,
    "tabWidth": 4,
    "trailingComma": "none"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "packageManager": "pnpm@10.34.1+sha512.b58fbde6dca66a929538021581f648b4570b6ca19b18e7cbd7f2c07a7b24454155388dacdf08f2af3678e88a6d1fe04f9d609df24bf51735a060ea041b374ab7"
}
