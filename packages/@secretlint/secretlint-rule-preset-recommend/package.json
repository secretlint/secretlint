{
    "name": "@secretlint/secretlint-rule-preset-recommend",
    "version": "11.7.1",
    "description": "Recommended rule preset of secretlint.",
    "keywords": [
        "secretlint",
        "rule",
        "rule-preset"
    ],
    "homepage": "https://github.com/secretlint/secretlint/tree/master/packages/@secretlint/secretlint-rule-preset-recommend/",
    "bugs": {
        "url": "https://github.com/secretlint/secretlint/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/secretlint/secretlint.git"
    },
    "license": "MIT",
    "author": "azu",
    "type": "module",
    "exports": {
        ".": {
            "import": {
                "types": "./module/index.d.ts",
                "default": "./module/index.js"
            },
            "default": "./module/index.js"
        },
        "./package.json": "./package.json"
    },
    "main": "./module/index.js",
    "types": "./module/index.d.ts",
    "directories": {
        "lib": "lib",
        "test": "test"
    },
    "files": [
        "bin/",
        "module/",
        "src/"
    ],
    "scripts": {
        "build": "rollup --config",
        "build:tsc": "tsc -p . --noEmit",
        "clean": "rimraf module/",
        "sync-canary": "cp ../secretlint-rule-preset-canary/src/index.ts src/ && sed -i '' -e 's/\\@secretlint\\/secretlint-rule-preset-canary/\\@secretlint\\/secretlint-rule-preset-recommend/' src/index.ts && cp -r ../secretlint-rule-preset-canary/test/ test && sed -i '' -e 's/\\@secretlint\\/secretlint-rule-preset-canary/\\@secretlint\\/secretlint-rule-preset-recommend/' test/index.test.ts && node cp-canary-deps.cjs && pnpm install && npm run build && npm run updateSnapshot",
        "prepublishOnly": "npm run clean && npm run build",
        "prettier": "prettier --write \"**/*.{js,jsx,ts,tsx,css}\"",
        "prepublish": "npm run --if-present build",
        "import-test": "node import-tests.js && npm run build && npm run updateSnapshot",
        "test": "node --import tsx --test test/index.test.ts",
        "updateSnapshot": "UPDATE_SNAPSHOT=1 npm test",
        "watch": "tsc --build --watch"
    },
    "prettier": {
        "printWidth": 120,
        "singleQuote": false,
        "tabWidth": 4
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "catalog:",
        "@rollup/plugin-node-resolve": "catalog:",
        "@rollup/plugin-typescript": "catalog:",
        "@secretlint/secretlint-rule-1password": "workspace:*",
        "@secretlint/secretlint-rule-anthropic": "workspace:*",
        "@secretlint/secretlint-rule-aws": "workspace:*",
        "@secretlint/secretlint-rule-azure": "workspace:*",
        "@secretlint/secretlint-rule-basicauth": "workspace:*",
        "@secretlint/secretlint-rule-database-connection-string": "workspace:*",
        "@secretlint/secretlint-rule-databricks": "workspace:*",
        "@secretlint/secretlint-rule-docker": "workspace:*",
        "@secretlint/secretlint-rule-figma": "workspace:*",
        "@secretlint/secretlint-rule-filter-comments": "workspace:*",
        "@secretlint/secretlint-rule-gcp": "workspace:*",
        "@secretlint/secretlint-rule-github": "workspace:*",
        "@secretlint/secretlint-rule-gitlab": "workspace:*",
        "@secretlint/secretlint-rule-grafana": "workspace:*",
        "@secretlint/secretlint-rule-groq": "workspace:*",
        "@secretlint/secretlint-rule-hashicorp-vault": "workspace:*",
        "@secretlint/secretlint-rule-huggingface": "workspace:*",
        "@secretlint/secretlint-rule-linear": "workspace:*",
        "@secretlint/secretlint-rule-notion": "workspace:*",
        "@secretlint/secretlint-rule-npm": "workspace:*",
        "@secretlint/secretlint-rule-openai": "workspace:*",
        "@secretlint/secretlint-rule-privatekey": "workspace:*",
        "@secretlint/secretlint-rule-sendgrid": "workspace:*",
        "@secretlint/secretlint-rule-shopify": "workspace:*",
        "@secretlint/secretlint-rule-slack": "workspace:*",
        "@secretlint/secretlint-rule-vercel": "workspace:*",
        "@secretlint/tester": "workspace:*",
        "@secretlint/types": "workspace:*",
        "@types/node": "catalog:",
        "prettier": "catalog:",
        "rimraf": "catalog:",
        "rollup": "catalog:",
        "rollup-plugin-polyfill-node": "catalog:",
        "tsx": "catalog:",
        "typescript": "catalog:"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
