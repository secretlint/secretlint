{
  "rules": [
    {
      "id": "@secretlint/secretlint-rule-pattern",
      "options": {
        "patterns": [
          {
            "name": "password=",
            "pattern": "/password\\s*=\\s*(?<password>[\\w\\d!@#$%^&(){}\\[\\]:\";'<>,.?/~`_+-=|]{1,256})\\b.*/gi",
            "allows": ["foo-bar-baz"]
          },
          {
            "name": "apikey=",
            "pattern": "/apikey\\s*=\\s*(?<apikey>[\\w\\d_-]{8,})\\b.*/gi"
          }
        ]
      }
    }
  ]
}
